{
  "manifest_version": 3,
  "name": "Interview Chance Checker",
  "version": "0.1.0",
  "description": "Send the current LinkedIn job posting to Interview Chance Checker.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Interview Chance Checker"
  },
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": ["http://localhost:5173/*"],
  "content_scripts": [
    {
      "matches": ["http://localhost:5173/*"],
      "js": ["appBridge.js"],
      "run_at": "document_idle"
    }
  ]
}
